set(VCPKG_TARGET_ARCHITECTURE x64)
set(VCPKG_CRT_LINKAGE dynamic)
set(VCPKG_LIBRARY_LINKAGE dynamic)
set(VCPKG_ENV_PASSTHROUGH PATH)

set(VCPKG_CMAKE_SYSTEM_NAME MinGW)
set(VCPKG_POLICY_DLLS_WITHOUT_LIBS enabled)

set(BIGOBJ_PORTS_LIST "UNKNOWN")
if(PORT IN_LIST BIGOBJ_PORTS_LIST)
  set(VCPKG_C_FLAGS "-Wa,-mbig-obj ")
  set(VCPKG_CXX_FLAGS "-Wa,-mbig-obj ")
endif()

set(COMBINED_STATIC_AND_DYNAMIC_LIBRARY_LINKING_PORTS_LIST "UNKNOWN")
if(PORT IN_LIST COMBINED_STATIC_AND_DYNAMIC_LIBRARY_LINKING_PORTS_LIST)
  set(VCPKG_COMBINED_STATIC_AND_DYNAMIC_LIBRARY_LINKING ON)
  list(APPEND VCPKG_CMAKE_CONFIGURE_OPTIONS "-DCMAKE_MAP_IMPORTED_CONFIG_RELWITHDEBINFO=Release")
  list(APPEND VCPKG_CMAKE_CONFIGURE_OPTIONS "-DCMAKE_MAP_IMPORTED_CONFIG_RELEASE=Release")
  list(APPEND VCPKG_CMAKE_CONFIGURE_OPTIONS "-DCMAKE_MAP_IMPORTED_CONFIG_DEBUG=Debug")
endif()
